APP_NAME=SilverBridge AI Server
APP_ENV=development
APP_VERSION=0.1.0
APP_PORT=6017
LOG_LEVEL=INFO

POSTGRES_HOST=localhost
POSTGRES_PORT=6019
POSTGRES_DB=silverbridge_ai
POSTGRES_USER=silverbridge_ai
POSTGRES_PASSWORD=silverbridge_ai_pw
DATABASE_URL=postgresql+psycopg2://silverbridge_ai:silverbridge_ai_pw@localhost:6019/silverbridge_ai
API_KEY=silverbridge_live_7XqP2mKa9LdR4tYu

MODEL_BASE_PATH=/app/models
UPLOAD_BASE_PATH=/app/uploads
SNAPSHOT_BASE_PATH=/app/uploads/snapshots
DEVICE_MAP=auto
TORCH_DTYPE=float16
REQUIRE_GPU=true

DEFAULT_CHAT_MODEL=google/medgemma-1.5-4b-it
CHAT_MODEL_PATH=
HF_TOKEN=

GPT_API_KEY=
GPT_MODEL_NAME=gpt-4o-mini
GPT_TIMEOUT_SEC=60

RESERVATION_API_BASE_URL=http://127.0.0.1:6015/api/v1
RESERVATION_API_TIMEOUT_SEC=120
RESERVATION_API_KEY=
RESERVATION_USER_JWT=
RESERVATION_ADMIN_JWT=
RESERVATION_SERVICE_EMAIL=user1@example.com
RESERVATION_SERVICE_PASSWORD=User123456!
# FE에서 발급받은 reservation API key를 저장해 두고 채팅 예약 호출에 재사용합니다.

DEFAULT_DETECTION_THRESHOLD=0.75
FIRE_SMOKE_ENABLED=true
FIRE_SMOKE_MODEL_PATH=fire_smoke.pt
FIRE_SMOKE_CONF_THRESHOLD=0.35
FIRE_SMOKE_IOU_THRESHOLD=0.45
STREAM_SAMPLE_EVERY_N_FRAMES=5
STREAM_FALLBACK_INTERVAL_SEC=2
SAVE_NORMAL_RESULTS=true
LIVE_STREAM_DISCONNECT_TIMEOUT_SEC=10
STREAM_STATE_BACKEND=memory

MEDIAMTX_ENABLED=false
MEDIAMTX_WEBRTC_INGEST_BASE=
MEDIAMTX_WEBRTC_VIEW_BASE=
MEDIAMTX_HLS_VIEW_BASE=

DOCS_PATH=/api/docs
OPENAPI_PATH=/api/openapi.json
REDOC_PATH=/api/redoc
